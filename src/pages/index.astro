---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={config.site.title} description={config.site.description}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-green-950 via-green-900 to-green-800 py-24 md:py-32 overflow-hidden">
    <!-- Subtle pattern overlay -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-amber-300 text-sm font-medium mb-6">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Serving the Bulkley Valley, BC
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
            Growing Beautiful Spaces <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">In the Bulkley Valley</span>
          </h1>
          <p class="text-lg md:text-xl text-blue-100 mb-8 max-w-xl leading-relaxed">
            From garden bed installation and patio hardscaping to custom plant starts and lawn care — Metta Growing brings thoughtful, hands-on landscaping to Smithers and the surrounding area.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
            >
              Get a Free Quote
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            {config.features.products && (
              <a
                href={`${base}services/`}
                class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all"
              >
                View Our Services
              </a>
            )}
          </div>
          <div class="flex items-center gap-6 mt-8 pt-8 border-t border-white/10">
            <div class="text-center">
              <div class="text-2xl font-bold text-white"><span data-count="5" data-suffix="+">0+</span></div>
              <div class="text-xs text-green-200 uppercase tracking-wide">Years Exp.</div>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white"><span data-count="100" data-suffix="+">0+</span></div>
              <div class="text-xs text-green-200 uppercase tracking-wide">Projects</div>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div class="text-center">
              <div class="flex text-amber-400">
                {[...Array(5)].map(() => (
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <div class="text-xs text-green-200 uppercase tracking-wide">5-Star Rating</div>
            </div>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src={`${base}assets/7efe9fb6-b907-4be8-8017-d3e5b741a6b4.jpg`}
            alt="Beautiful cobblestone patio installed by Metta Growing in Smithers BC"
            class="w-full h-auto max-h-[500px] object-contain drop-shadow-2xl"
            fetchpriority="high"
            width="500"
            height="500"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-green-950 via-green-900 to-green-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Trust Bar -->
  <section class="bg-white border-b border-gray-100 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center stagger-children">
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-blue-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-sm font-semibold text-gray-900">Locally Rooted</span>
        </div>
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-green-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-sm font-semibold text-gray-900">Reliable & On-Time</span>
        </div>
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-green-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-sm font-semibold text-gray-900">Eco-Conscious</span>
        </div>
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-green-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <span class="text-sm font-semibold text-gray-900">Quality Workmanship</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Why Smithers Chooses Metta Growing
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          We combine deep local knowledge with genuine care for every plant, stone, and project we touch.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll card-hover relative p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="card-icon w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Locally Owned & Operated</h3>
          <p class="text-gray-600 leading-relaxed">
            Based in Smithers, BC, Metta Growing is a one-person business that knows this landscape intimately — the climate, the soil, and what grows well here.
          </p>
        </div>

        <div class="animate-on-scroll card-hover relative p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="card-icon w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Full-Service Growing</h3>
          <p class="text-gray-600 leading-relaxed">
            From seedling to finished garden — plant starts, landscape installation, hardscaping, and maintenance all under one roof. No project too small or too creative.
          </p>
        </div>

        <div class="animate-on-scroll card-hover relative p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="card-icon w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Honest Pricing</h3>
          <p class="text-gray-600 leading-relaxed">
            Clear, upfront quotes with no surprises. You'll know exactly what to expect before any work begins — because trust matters more than any single job.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">About Summit Pro Builders</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6">
            Built on Trust, Delivered With Pride
          </h2>
          <p class="text-lg text-gray-600 mb-6">
            Since 2009, we've been transforming homes across the Denver metro area. What started as a two-person crew has grown into a full-service general contracting firm with a dedicated team of craftsmen, project managers, and designers.
          </p>
          <p class="text-lg text-gray-600 mb-8">
            Every project begins with listening. We take time to understand your vision, your budget, and your timeline, then build a plan that brings it all together.
          </p>
          <a
            href={`${base}about/`}
            class="inline-flex items-center text-blue-600 font-semibold hover:text-blue-700 transition-colors group"
          >
            Learn more about our story
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="relative">
          <img
            src={`${base}assets/hero-image.svg`}
            alt="Summit Pro Builders team at work"
            class="rounded-2xl shadow-lg w-full h-80 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {config.features.testimonials && (
    <!-- Testimonials Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 animate-on-scroll">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            What Our Clients Say
          </h2>
          <p class="text-xl text-gray-600">
            Real stories from Denver homeowners we've worked with.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
          <!-- Testimonial 1 -->
          <div class="animate-on-scroll bg-gray-50 p-8 rounded-2xl border border-gray-100">
            <div class="flex items-center mb-4">
              <div class="flex text-amber-400">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-6 leading-relaxed">
              "Summit Pro completely transformed our 1970s kitchen. They managed everything from permits to the final walkthrough. Came in on budget and two days early. Couldn't be happier."
            </p>
            <div class="flex items-center">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4">
                <span class="text-blue-600 font-bold text-lg">JM</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Jennifer Martinez</p>
                <p class="text-sm text-gray-500">Kitchen Remodel, Highlands Ranch</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="animate-on-scroll bg-gray-50 p-8 rounded-2xl border border-gray-100">
            <div class="flex items-center mb-4">
              <div class="flex text-amber-400">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-6 leading-relaxed">
              "We added a 400 sq ft family room and it blends perfectly with the existing house. The team was professional, clean, and communicated every step of the way."
            </p>
            <div class="flex items-center">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4">
                <span class="text-blue-600 font-bold text-lg">DT</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900">David Thompson</p>
                <p class="text-sm text-gray-500">Home Addition, Lakewood</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div class="animate-on-scroll bg-gray-50 p-8 rounded-2xl border border-gray-100">
            <div class="flex items-center mb-4">
              <div class="flex text-amber-400">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <p class="text-gray-600 mb-6 leading-relaxed">
              "Our master bathroom went from dated to spa-quality. The tile work is stunning and the heated floors were worth every penny. Summit Pro is our go-to contractor now."
            </p>
            <div class="flex items-center">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4">
                <span class="text-blue-600 font-bold text-lg">SR</span>
              </div>
              <div>
                <p class="font-semibold text-gray-900">Sarah Richardson</p>
                <p class="text-sm text-gray-500">Bathroom Renovation, Boulder</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Guarantees Section -->
  <section class="py-16 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 animate-on-scroll">
        <h2 class="text-2xl md:text-3xl font-bold text-white">Our Promise to You</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 bg-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">On-Time Guarantee</h3>
          <p class="text-sm text-gray-400 leading-relaxed">We set a completion date and stick to it. If we miss our deadline, you get a discount. Period.</p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 bg-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">No Hidden Fees</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Every cost is in writing before work begins. If the scope changes, you approve the cost first.</p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-16 h-16 bg-amber-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">2-Year Warranty</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Full workmanship warranty on all labor and installation. We stand behind every project we complete.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Website Services CTA -->
  <!-- Website Services Showcase -->
