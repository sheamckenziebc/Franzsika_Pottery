  <!-- Sticky CTA script -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const stickyCta = document.getElementById('templates-sticky-cta');
      const stickyCtaMobile = document.getElementById('templates-sticky-cta-mobile');
      const pricingSection = document.getElementById('pricing');

      function updateStickyCtas() {
        const scrollY = window.scrollY;
        const pricingTop = pricingSection ? pricingSection.getBoundingClientRect().top : Infinity;
        const pricingBottom = pricingSection ? pricingSection.getBoundingClientRect().bottom : Infinity;
        const isInPricing = pricingTop < window.innerHeight && pricingBottom > 0;
        const show = scrollY > 600 && !isInPricing;
        const transform = show ? 'translateY(0)' : 'translateY(100%)';

        if (stickyCta) stickyCta.style.transform = transform;
        if (stickyCtaMobile) stickyCtaMobile.style.transform = transform;
      }

      window.addEventListener('scroll', updateStickyCtas, { passive: true });
    });
  </script>

