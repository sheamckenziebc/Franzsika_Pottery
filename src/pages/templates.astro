  <!-- ROI Calculator Script -->
  <script>
    document.addEventListener('astro:page-load', () => {
      const input = document.getElementById('avg-job') as HTMLInputElement;
      const starterEl = document.getElementById('roi-starter');
      const proEl = document.getElementById('roi-pro');
      const entEl = document.getElementById('roi-enterprise');
      const summaryEl = document.getElementById('roi-summary');
      if (!input) return;

      function calc() {
        const val = Math.max(parseFloat(input.value) || 0, 1);
        const starter = Math.ceil(497 / val);
        const pro = Math.ceil(997 / val);
        const ent = Math.ceil(1997 / val);
        if (starterEl) starterEl.textContent = starter === 1 ? '1 job' : `${starter} jobs`;
        if (proEl) proEl.textContent = pro === 1 ? '1 job' : `${pro} jobs`;
        if (entEl) entEl.textContent = ent === 1 ? '1 job' : `${ent} jobs`;
        if (summaryEl) {
          const formatted = val.toLocaleString('en-US', { maximumFractionDigits: 0 });
          const proText = pro === 1 ? 'first customer' : `first ${pro} customers`;
          summaryEl.innerHTML = `At <strong class="text-white">$${formatted}</strong> per job, the Professional plan pays for itself with your <strong class="text-amber-400">${proText}</strong>.`;
        }
      }

      input.addEventListener('input', calc);
      calc();
    });
  </script>

