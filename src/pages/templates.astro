---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const templates = [
  {
    name: "Starter",
    price: "$497",
    period: "one-time",
    description: "Everything a new business needs to get online fast.",
    features: [
      "5-page responsive website",
      "Mobile-optimized design",
      "Contact form with email notifications",
      "Google Maps integration",
      "Basic SEO setup",
      "SSL certificate included",
      "1 round of revisions",
    ],
    notIncluded: [
      "Blog functionality",
      "Custom domain setup",
      "Ongoing maintenance",
    ],
    cta: "Get Started",
    popular: false,
    color: "blue"
  },
  {
    name: "Professional",
    price: "$997",
    period: "one-time",
    description: "The complete package for serious businesses ready to grow.",
    features: [
      "9-page responsive website",
      "Mobile-optimized + tablet tested",
      "Contact form with smart routing",
      "Google Maps integration",
      "Blog with 3 starter articles",
      "FAQ page with structured data",
      "Advanced SEO (Schema markup, sitemap, meta tags)",
      "Social media integration",
      "Google Analytics setup",
      "Custom domain setup",
      "2 rounds of revisions",
      "30 days of post-launch support",
    ],
    notIncluded: [
      "Monthly content updates",
    ],
    cta: "Most Popular",
    popular: true,
    color: "amber"
  },
  {
    name: "Enterprise",
    price: "$1,997",
    period: "one-time",
    description: "Full-service web presence for established businesses scaling up.",
    features: [
      "Unlimited pages",
      "Custom design to match your brand",
      "Mobile + tablet + desktop optimized",
      "Advanced contact forms with file uploads",
      "Blog with content strategy",
      "FAQ, testimonials, portfolio pages",
      "Full SEO audit and optimization",
      "Google Business Profile optimization",
      "Social media integration + sharing",
      "Analytics dashboard setup",
      "Custom domain + email setup",
      "Speed optimization (90+ Lighthouse)",
      "Unlimited revisions",
      "90 days of post-launch support",
      "Priority response time",
    ],
    notIncluded: [],
    cta: "Contact Us",
    popular: false,
    color: "blue"
  }
];

const industries = [
  { name: "General Contractors", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
  { name: "Plumbers", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" },
  { name: "Electricians", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "HVAC Companies", icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
  { name: "Roofers", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
  { name: "Landscapers", icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" },
  { name: "Painters", icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" },
  { name: "Auto Shops", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
];

const faqs = [
  {
    question: "What's included in the one-time price?",
    answer: "Design, development, deployment, and everything listed in your chosen tier. No monthly fees unless you opt for our hosting/maintenance add-on ($29/mo). You own the code."
  },
  {
    question: "How long does it take to build?",
    answer: "Starter: 5-7 business days. Professional: 10-14 business days. Enterprise: 3-4 weeks. We work fast because we start from proven templates, not blank screens."
  },
  {
    question: "Do I own the website?",
    answer: "100%. You get the full source code, hosting can be anywhere (we recommend GitHub Pages - it's free), and you're never locked into a contract."
  },
  {
    question: "What if I need changes later?",
    answer: "Your revision rounds are included in the price. After launch, you can make changes yourself (it's just HTML), hire any developer, or add our maintenance plan for $29/month."
  },
  {
    question: "Do you build on WordPress?",
    answer: "No. We build static sites using modern tools (Astro + Tailwind CSS). They're faster, more secure, cheaper to host, and don't need constant updates. Your site loads in under 1 second."
  },
  {
    question: "Can I see a live demo?",
    answer: "You're looking at one. This entire site is built with our Professional template. Every page, every animation, every feature you see here is included."
  }
];
---

<BaseLayout title={`Website Templates for Blue Collar Businesses | ${config.site.title}`} description="Professional website templates built for contractors, plumbers, electricians, and trades businesses. Transparent pricing. No monthly fees. Fast delivery.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-amber-300 text-sm font-medium mb-6">
        No monthly fees. You own everything.
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
        Websites That Work <br class="hidden md:block"/><span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">As Hard As You Do</span>
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed mb-8">
        Professional websites built specifically for trades and blue collar businesses. No subscriptions, no page builders, no BS. Just fast, professional sites that bring in leads.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href="#pricing" class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg">
          See Pricing
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
        <a href="#demo" class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all">
          See Live Demo
        </a>
      </div>

      <!-- Hero Social Proof -->
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 pt-8 border-t border-white/10">
        <div class="text-center">
          <p class="text-2xl font-extrabold text-white">47+</p>
          <p class="text-xs text-blue-300">Sites Built</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-extrabold text-white">8 days</p>
          <p class="text-xs text-blue-300">Avg. Delivery</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-extrabold text-amber-400">4.9/5</p>
          <p class="text-xs text-blue-300">Client Rating</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-extrabold text-green-400">$0</p>
          <p class="text-xs text-blue-300">Monthly Fees</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Problem Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-red-500 font-semibold text-sm uppercase tracking-wider">The Hard Truth</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Is Your Online Presence Costing You Jobs?</h2>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto">
          While you're doing great work, your competitors are getting found online first.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto stagger-children">
        <div class="animate-on-scroll flex items-start gap-4 p-5 bg-red-50 rounded-xl border border-red-100">
          <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">No Website At All</h3>
            <p class="text-sm text-gray-600">97% of people search online before hiring a local service. No site = invisible to most customers.</p>
          </div>
        </div>

        <div class="animate-on-scroll flex items-start gap-4 p-5 bg-red-50 rounded-xl border border-red-100">
          <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Outdated or Ugly Site</h3>
            <p class="text-sm text-gray-600">75% of people judge your credibility by your website. That 2015 design is costing you trust before you even pick up the phone.</p>
          </div>
        </div>

        <div class="animate-on-scroll flex items-start gap-4 p-5 bg-red-50 rounded-xl border border-red-100">
          <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Bleeding Monthly Fees</h3>
            <p class="text-sm text-gray-600">Wix, Squarespace, WordPress hosting — $50-$200/month adds up to thousands. That's money off your bottom line, every year.</p>
          </div>
        </div>

        <div class="animate-on-scroll flex items-start gap-4 p-5 bg-red-50 rounded-xl border border-red-100">
          <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Losing to the Other Guy</h3>
            <p class="text-sm text-gray-600">Homeowners compare 3-4 contractors before calling. The one with the professional website gets the first call.</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <p class="text-lg font-semibold text-gray-900 mb-4">Ready to fix this? It takes less than two weeks.</p>
        <a href="#pricing" class="inline-flex items-center justify-center bg-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
          See Your Options
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Before vs After -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">See the Difference</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">What Your Customers See Right Now vs. What They Could See</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 animate-on-scroll">
        <!-- Before -->
        <div class="relative">
          <div class="absolute -top-3 left-4 bg-red-500 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full z-10">Before</div>
          <div class="bg-white rounded-2xl border-2 border-red-200 overflow-hidden shadow-sm">
            <!-- Fake browser bar -->
            <div class="bg-gray-100 px-4 py-2 flex items-center gap-2 border-b border-gray-200">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
              </div>
              <div class="flex-1 bg-white rounded text-xs text-gray-400 px-3 py-1 text-center">your-business.com</div>
            </div>
            <!-- Fake bad website -->
            <div class="p-6 space-y-4">
              <div class="h-8 bg-gray-300 rounded w-2/3"></div>
              <div class="flex gap-4">
                <div class="h-3 bg-gray-200 rounded flex-1"></div>
                <div class="h-3 bg-gray-200 rounded flex-1"></div>
                <div class="h-3 bg-gray-200 rounded flex-1"></div>
              </div>
              <div class="h-32 bg-gray-100 rounded-lg border-2 border-dashed border-gray-300 flex items-center justify-center">
                <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
              <div class="space-y-2">
                <div class="h-3 bg-gray-200 rounded w-full"></div>
                <div class="h-3 bg-gray-200 rounded w-5/6"></div>
                <div class="h-3 bg-gray-200 rounded w-4/6"></div>
              </div>
              <div class="h-8 bg-gray-300 rounded w-1/3"></div>
            </div>
          </div>
          <ul class="mt-4 space-y-2">
            <li class="flex items-center gap-2 text-sm text-red-600"><svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>Slow loading, low PageSpeed score</li>
            <li class="flex items-center gap-2 text-sm text-red-600"><svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>No mobile optimization</li>
            <li class="flex items-center gap-2 text-sm text-red-600"><svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>Generic template look, no trust</li>
            <li class="flex items-center gap-2 text-sm text-red-600"><svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>$50-200/month just to keep it running</li>
          </ul>
        </div>

        <!-- After -->
        <div class="relative">
          <div class="absolute -top-3 left-4 bg-green-500 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full z-10">After</div>
          <div class="bg-white rounded-2xl border-2 border-green-200 overflow-hidden shadow-lg ring-1 ring-green-100">
            <!-- Fake browser bar -->
            <div class="bg-gray-100 px-4 py-2 flex items-center gap-2 border-b border-gray-200">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
              </div>
              <div class="flex-1 bg-white rounded text-xs text-gray-700 px-3 py-1 text-center font-medium flex items-center justify-center gap-1">
                <svg class="w-3 h-3 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                yourbusiness.com
              </div>
            </div>
            <!-- Fake good website -->
            <div class="p-6 space-y-4">
              <div class="bg-gradient-to-r from-slate-900 to-blue-900 rounded-lg p-4">
                <div class="h-3 bg-white/30 rounded w-1/3 mb-2"></div>
                <div class="h-5 bg-white/80 rounded w-2/3 mb-2"></div>
                <div class="h-3 bg-white/40 rounded w-1/2 mb-3"></div>
                <div class="h-7 bg-amber-500 rounded w-1/3"></div>
              </div>
              <div class="flex gap-3">
                <div class="flex-1 bg-blue-50 rounded-lg p-3 border border-blue-100">
                  <div class="w-6 h-6 bg-blue-600 rounded mb-2"></div>
                  <div class="h-3 bg-blue-200 rounded w-2/3 mb-1"></div>
                  <div class="h-2 bg-blue-100 rounded w-full"></div>
                </div>
                <div class="flex-1 bg-blue-50 rounded-lg p-3 border border-blue-100">
                  <div class="w-6 h-6 bg-blue-600 rounded mb-2"></div>
                  <div class="h-3 bg-blue-200 rounded w-2/3 mb-1"></div>
                  <div class="h-2 bg-blue-100 rounded w-full"></div>
                </div>
                <div class="flex-1 bg-blue-50 rounded-lg p-3 border border-blue-100">
                  <div class="w-6 h-6 bg-blue-600 rounded mb-2"></div>
                  <div class="h-3 bg-blue-200 rounded w-2/3 mb-1"></div>
                  <div class="h-2 bg-blue-100 rounded w-full"></div>
                </div>
              </div>
              <div class="flex gap-2 items-center">
                <div class="flex -space-x-1">
                  <div class="w-5 h-5 rounded-full bg-amber-400 border border-white"></div>
                  <div class="w-5 h-5 rounded-full bg-amber-400 border border-white"></div>
                  <div class="w-5 h-5 rounded-full bg-amber-400 border border-white"></div>
                  <div class="w-5 h-5 rounded-full bg-amber-400 border border-white"></div>
                  <div class="w-5 h-5 rounded-full bg-amber-400 border border-white"></div>
                </div>
                <div class="h-2 bg-gray-200 rounded w-1/3"></div>
              </div>
            </div>
          </div>
