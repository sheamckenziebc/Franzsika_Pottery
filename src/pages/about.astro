---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;

// Pre-compute JSON-LD for about page
const aboutLogoUrl = new URL(config.branding.logo, Astro.site).href;
const contactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email };
contactPt["@type"] = "ContactPoint";
const addr: Record<string, any> = { streetAddress: config.contact.address };
addr["@type"] = "PostalAddress";
const mainEntity: Record<string, any> = { name: config.site.title, description: config.site.description, url: config.site.url, logo: aboutLogoUrl, contactPoint: contactPt, address: addr };
mainEntity["@type"] = "Organization";
const aboutObj: Record<string, any> = { mainEntity };
aboutObj["@context"] = "https://schema.org";
aboutObj["@type"] = "AboutPage";
const aboutJsonLd = JSON.stringify(aboutObj);
---

<BaseLayout title={`About Us | ${config.site.title}`} description={`Learn about Summit Pro Builders — Denver's trusted general contractor with 15+ years of experience in home remodeling and renovations.`}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">Our Story</span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mt-2 mb-6">
          Building Denver's Homes <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">Since 2009</span>
        </h1>
        <p class="text-xl text-blue-100 leading-relaxed">
          What started as a two-person crew with a shared passion for quality craftsmanship has grown into one of the Denver metro's most trusted general contracting firms.
        </p>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Company Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            From Foundation to Finish
          </h2>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            Summit Pro Builders was founded by Marcus Cole and Ryan Nguyen, two journeyman carpenters who believed Denver homeowners deserved better than the typical contractor experience: missed deadlines, surprise costs, and shoddy workmanship.
          </p>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            They started by taking on kitchen remodels in their own neighborhood, earning trust one project at a time. Word spread quickly. Fifteen years later, we've completed over 500 residential projects across the Front Range, from custom home additions in Cherry Creek to whole-home renovations in Boulder.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            Our promise remains the same as day one: honest estimates, quality craftsmanship, and a finished product you'll be proud to call home.
          </p>
        </div>
        <div class="relative">
          <img
            src={`${base}assets/about-story.svg`}
            alt="Summit Pro Builders team on a job site"
            class="rounded-2xl shadow-lg w-full h-96 object-cover"
            loading="lazy"
          />
          <!-- Stats overlay -->
          <div class="absolute -bottom-8 left-8 right-8 bg-white rounded-xl shadow-xl p-6 grid grid-cols-3 gap-4 text-center">
            <div>
              <div class="text-3xl font-extrabold text-blue-600"><span data-count="15" data-suffix="+">0+</span></div>
              <div class="text-sm text-gray-500 font-medium">Years in Business</div>
            </div>
            <div class="border-l border-r border-gray-200">
              <div class="text-3xl font-extrabold text-blue-600"><span data-count="500" data-suffix="+">0+</span></div>
              <div class="text-sm text-gray-500 font-medium">Projects Completed</div>
            </div>
            <div>
              <div class="text-3xl font-extrabold text-blue-600"><span data-count="4.9" data-suffix="">0</span></div>
              <div class="text-sm text-gray-500 font-medium">Avg. Rating</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">What We Stand For</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">
          Our Core Values
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          These principles guide every project we take on and every relationship we build.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll card-hover bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="card-icon w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Safety First</h3>
          <p class="text-gray-600 leading-relaxed">
            OSHA-compliant job sites, proper permitting, and thorough inspections at every stage. We never cut corners when it comes to the safety of our team and your family.
          </p>
        </div>

        <div class="animate-on-scroll card-hover bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="card-icon w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">On-Time Delivery</h3>
          <p class="text-gray-600 leading-relaxed">
            We set realistic timelines and stick to them. Our project managers coordinate every trade so your renovation stays on schedule, because we know life doesn't stop for a remodel.
          </p>
        </div>

        <div class="animate-on-scroll card-hover bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="card-icon w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Quality Without Compromise</h3>
          <p class="text-gray-600 leading-relaxed">
            Premium materials, skilled tradespeople, and rigorous quality checks. We build every home as if it were our own, backed by a comprehensive warranty on all workmanship.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">The People Behind the Projects</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">
          Meet Our Leadership
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Experienced professionals dedicated to delivering exceptional results on every project.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll bg-gray-50 rounded-2xl p-8 text-center border border-gray-100">
          <div class="w-24 h-24 bg-blue-600 rounded-full mx-auto mb-6 flex items-center justify-center">
            <span class="text-3xl font-bold text-white">MC</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-1">Marcus Cole</h3>
          <p class="text-blue-600 font-semibold mb-4">Co-Founder & Lead Estimator</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            20 years in residential construction. Licensed general contractor with a keen eye for detail and a reputation for accurate, honest estimates. Builds trust before he builds walls.
          </p>
        </div>

        <div class="animate-on-scroll bg-gray-50 rounded-2xl p-8 text-center border border-gray-100">
          <div class="w-24 h-24 bg-blue-600 rounded-full mx-auto mb-6 flex items-center justify-center">
            <span class="text-3xl font-bold text-white">RN</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-1">Ryan Nguyen</h3>
          <p class="text-blue-600 font-semibold mb-4">Co-Founder & Project Director</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Oversees every active project from permits to punch list. Journeyman carpenter turned operations leader. Known for keeping jobs on time and crews motivated.
          </p>
        </div>

        <div class="animate-on-scroll bg-gray-50 rounded-2xl p-8 text-center border border-gray-100">
          <div class="w-24 h-24 bg-blue-600 rounded-full mx-auto mb-6 flex items-center justify-center">
            <span class="text-3xl font-bold text-white">TP</span>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-1">Teresa Padilla</h3>
          <p class="text-blue-600 font-semibold mb-4">Design Consultant</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Interior design degree from CU Denver and 10 years of residential remodel experience. Helps homeowners turn Pinterest boards into buildable plans that fit their budget.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">Where We Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2">
          Serving the Denver <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">Metro Area</span>
        </h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">From Boulder to Castle Rock, we bring quality craftsmanship to communities across the Front Range.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 animate-on-scroll">
        {["Denver", "Boulder", "Lakewood", "Highlands Ranch", "Arvada", "Golden", "Littleton", "Aurora", "Parker", "Castle Rock"].map((city) => (
          <div class="flex items-center gap-2 bg-white rounded-xl px-4 py-3 border border-gray-200">
            <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm font-medium text-gray-700">{city}</span>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-gray-400 mt-6 animate-on-scroll">Don't see your area? <a href={`${base}contact/`} class="text-blue-600 hover:underline">Contact us</a> — we may still be able to help.</p>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="relative py-20 bg-gradient-to-br from-blue-700 to-blue-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.2&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Let's Build Something Great Together
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Schedule a free consultation and let us show you why hundreds of Denver homeowners trust Summit Pro Builders with their most important investment.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg"
        >
          Schedule a Consultation
        </a>
        <a
          href={`tel:${config.contact.phone}`}
          class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Us Today
        </a>
      </div>
    </div>
  </section>

  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={aboutJsonLd} />

  <Footer slot="footer" />
</BaseLayout>
