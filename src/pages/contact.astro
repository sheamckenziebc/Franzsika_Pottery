---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

// Load configuration
const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;

// Pre-compute JSON-LD for contact page
const cContactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email, availableLanguage: "English" };
cContactPt["@type"] = "ContactPoint";
const cAddr: Record<string, any> = { streetAddress: config.contact.address };
cAddr["@type"] = "PostalAddress";
const cMainEntity: Record<string, any> = { name: config.site.title, contactPoint: cContactPt, address: cAddr };
cMainEntity["@type"] = "Organization";
const contactObj: Record<string, any> = { mainEntity: cMainEntity };
contactObj["@context"] = "https://schema.org";
contactObj["@type"] = "ContactPage";
const contactJsonLd = JSON.stringify(contactObj);

// Map data for client-side script
const mapLat = config.integrations.map_coordinates.lat;
const mapLng = config.integrations.map_coordinates.lng;
const mapTitle = config.site.title;
const mapAddress = config.contact.address;
---

<BaseLayout title={`Contact Us | ${config.site.title}`} description={`Get in touch with ${config.site.title}. We're here to help with your needs.`}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">Get In Touch</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mt-2 mb-6">
        Start Your <span class="text-amber-400">Project Today</span>
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
        Tell us about your renovation and get a free, detailed estimate within 48 hours. No pressure, no obligation.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">Send Us a Message</h2>
          <p class="text-gray-500 mb-8">Fill out the form and we'll get back to you within one business day.</p>

          <form
            action={`https://formspree.io/f/${config.integrations.formspree_id}`}
            method="POST"
            class="space-y-6"
            id="contact-form"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                Your Name *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                placeholder="John Smith"
                autocomplete="name"
              />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                  Phone Number *
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                  placeholder="(720) 555-0193"
                  autocomplete="tel"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                  Email Address
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                  placeholder="john@example.com"
                  autocomplete="email"
                />
              </div>
            </div>

            <div>
              <label for="project-type" class="block text-sm font-medium text-gray-700 mb-2">
                Project Type *
              </label>
              <select
                id="project-type"
                name="project-type"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              >
                <option value="">What can we help you with?</option>
                <option value="kitchen-remodel">Kitchen Remodel</option>
                <option value="bathroom-renovation">Bathroom Renovation</option>
                <option value="home-addition">Home Addition</option>
                <option value="basement-finish">Basement Finishing</option>
                <option value="deck-patio">Deck or Patio</option>
                <option value="whole-home">Whole-Home Renovation</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
                Tell Us About Your Project *
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                placeholder="What are you looking to renovate? Any timeline or budget in mind?"
              ></textarea>
            </div>

            <!-- Honeypot for spam protection -->
            <input type="text" name="_gotcha" style="display:none" />

            <button
              type="submit"
              class="w-full bg-blue-600 text-white py-3.5 px-6 rounded-lg font-semibold text-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Get Your Free Estimate
            </button>
            <p class="text-xs text-gray-400 text-center mt-2">We respond within 24 hours. No obligation.</p>
          </form>

          <!-- Form Status Messages -->
          <div id="form-status" class="mt-4 p-4 rounded-md hidden" aria-live="polite" role="status">
            <p id="form-message"></p>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">Get In Touch</h2>
          <p class="text-gray-500 mb-8">We're available during business hours and respond to messages within 24 hours.</p>

          <div class="space-y-6">
            <!-- Address -->
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Address</h3>
                <p class="text-gray-600">{config.contact.address}</p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Phone</h3>
                <a href={`tel:${config.contact.phone}`} class="text-blue-600 hover:text-blue-700 transition-colors">
                  {config.contact.phone}
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Email</h3>
                <a href={`mailto:${config.contact.email}`} class="text-blue-600 hover:text-blue-700 transition-colors">
                  {config.contact.email}
                </a>
              </div>
            </div>

            <!-- Business Hours -->
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Business Hours</h3>
                <p class="text-gray-600">{config.contact.businessHours}</p>
              </div>
            </div>
          </div>

          <!-- Response Time -->
          <div class="mt-8 p-4 bg-blue-50 rounded-lg">
            <h3 class="text-lg font-semibold text-blue-900 mb-2">Quick Response</h3>
            <p class="text-blue-700">
              We typically respond to all inquiries within 24 hours during business days.
              For urgent matters, please call us directly.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Find Us</h2>
        <p class="text-xl text-gray-600">Visit our location or get directions</p>
      </div>

      <!-- Map Container -->
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div id="map" class="h-96 w-full bg-gray-200 flex items-center justify-center">
          <div class="text-center">
            <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-gray-500">Interactive Map</p>
            <p class="text-sm text-gray-400 mt-2">{config.contact.address}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={contactJsonLd} />

  <!-- Map data passed to client -->
  <div id="map-data" data-lat={mapLat} data-lng={mapLng} data-title={mapTitle} data-address={mapAddress} style="display:none;"></div>

  <!-- Form submission handling -->
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formStatus = document.getElementById('form-status');
    const formMessage = document.getElementById('form-message');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Sending...';
        }

        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });

          if (response.ok) {
            formStatus!.className = 'mt-4 p-4 rounded-md bg-green-50 border border-green-200';
            formMessage!.textContent = 'Thank you for your message! We\'ll get back to you within 24 hours.';
            formMessage!.className = 'text-green-800 font-medium';
            form.reset();
          } else {
            throw new Error('Form submission failed');
          }
        } catch {
          formStatus!.className = 'mt-4 p-4 rounded-md bg-red-50 border border-red-200';
          formMessage!.textContent = 'Sorry, there was an error sending your message. Please try again or call us directly.';
          formMessage!.className = 'text-red-800 font-medium';
        }

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
        }
        formStatus!.classList.remove('hidden');
      });
    }

    // Lazy-load Leaflet map when map section scrolls into view
    const mapContainer = document.getElementById('map');
    if (mapContainer) {
      const mapObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            mapObserver.unobserve(entry.target);
            // Load Leaflet CSS
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
            document.head.appendChild(link);
            // Load Leaflet JS
            const script = document.createElement('script');
            script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
            script.onload = () => {
              const mapData = document.getElementById('map-data');
              if (!mapData) return;
              const lat = parseFloat(mapData.dataset.lat || '0');
              const lng = parseFloat(mapData.dataset.lng || '0');
              const title = mapData.dataset.title || '';
              const address = mapData.dataset.address || '';
              const map = (window as any).L.map('map').setView([lat, lng], 15);
              (window as any).L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
              }).addTo(map);
              (window as any).L.marker([lat, lng]).addTo(map)
                .bindPopup('<b>' + title + '</b><br>' + address)
                .openPopup();
            };
            document.body.appendChild(script);
          }
        });
      }, { rootMargin: '200px' });
      mapObserver.observe(mapContainer);
    }
  </script>

  <Footer slot="footer" />
</BaseLayout>
