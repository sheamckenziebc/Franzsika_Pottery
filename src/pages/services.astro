---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const services = [
  {
    title: "Kitchen Remodeling",
    description: "Complete kitchen transformations including custom cabinetry, countertops, flooring, lighting, and appliance installation. We handle everything from layout redesign to the finishing touches.",
    icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
    price: "Starting at $25,000"
  },
  {
    title: "Bathroom Renovation",
    description: "From powder room updates to luxury master bath overhauls. Tile work, vanities, walk-in showers, soaking tubs, heated floors, and ADA-accessible designs.",
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    price: "Starting at $15,000"
  },
  {
    title: "Home Additions",
    description: "Expand your living space with seamless room additions, second-story builds, sunrooms, and in-law suites that match your home's existing architecture.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    price: "Starting at $50,000"
  },
  {
    title: "Decks & Outdoor Living",
    description: "Custom decks, covered patios, pergolas, and outdoor kitchens built to withstand Colorado's climate. Composite and natural wood options available.",
    icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z",
    price: "Starting at $12,000"
  },
  {
    title: "Basement Finishing",
    description: "Transform unused basement space into entertainment rooms, home offices, guest suites, or rental units. Full egress, plumbing, and electrical included.",
    icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10",
    price: "Starting at $30,000"
  },
  {
    title: "Whole-Home Renovation",
    description: "Comprehensive remodels that reinvent your entire living space. Ideal for older homes that need structural updates, modern systems, and a fresh design throughout.",
    icon: "M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z",
    price: "Custom pricing"
  }
];

const process_steps = [
  { step: "01", title: "Consultation", description: "We visit your home, listen to your vision, and take detailed measurements. You'll receive a comprehensive estimate within 48 hours." },
  { step: "02", title: "Design & Planning", description: "Our design team creates plans and material selections. We handle all permits, HOA approvals, and utility coordination." },
  { step: "03", title: "Build", description: "Your dedicated project manager oversees daily progress. Expect clean job sites, clear communication, and quality at every stage." },
  { step: "04", title: "Final Walkthrough", description: "We walk every detail together. Nothing is complete until you're 100% satisfied. Backed by our comprehensive workmanship warranty." }
];

// JSON-LD Service schema
const serviceItems = services.map(s => {
  const item: Record<string, any> = { name: s.title, description: s.description };
  item["@type"] = "Service";
  return item;
});
const serviceProvider: Record<string, any> = { name: config.site.title, url: config.site.url };
serviceProvider["@type"] = "LocalBusiness";
const serviceObj: Record<string, any> = { provider: serviceProvider, hasOfferCatalog: { itemListElement: serviceItems } };
serviceObj["@context"] = "https://schema.org";
serviceObj["@type"] = "Service";
serviceObj.hasOfferCatalog["@type"] = "OfferCatalog";
const serviceJsonLd = JSON.stringify(serviceObj);
---

<BaseLayout title={`Our Services | ${config.site.title}`} description="Explore Summit Pro Builders' full range of residential construction services including kitchen remodels, bathroom renovations, home additions, and more.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">What We Do</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mt-2 mb-6">
        Residential Construction <span class="bg-gradient-to-r from-amber-300 to-amber-500 bg-clip-text text-transparent">Services</span>
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
        From single-room upgrades to whole-home transformations, we bring expert craftsmanship and transparent pricing to every project.
      </p>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Services Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {services.map((service) => (
          <div class="animate-on-scroll group bg-gray-50 rounded-2xl border border-gray-100 p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-amber-500 transition-colors">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{service.title}</h3>
            <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
            <div class="flex items-center justify-between pt-4 border-t border-gray-200">
              <span class="text-sm font-semibold text-blue-600">{service.price}</span>
              <a href={`${base}contact/`} class="text-sm font-semibold text-gray-500 hover:text-blue-600 transition-colors inline-flex items-center">
                Get Quote
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Projects -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">Our Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Recent Projects</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          A sample of renovations we've completed for Denver-area homeowners.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-amber-100 to-amber-200 flex items-center justify-center relative overflow-hidden">
            <svg class="w-16 h-16 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            <div class="absolute top-3 right-3 bg-white/90 text-xs font-bold text-gray-700 px-2 py-1 rounded-full">Kitchen</div>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Modern Farmhouse Kitchen</h3>
            <p class="text-sm text-gray-500 mb-3">Highlands Ranch, CO</p>
            <p class="text-sm text-gray-600 leading-relaxed">Full gut renovation with custom shaker cabinetry, quartz countertops, and a 10-foot waterfall island. Completed in 8 weeks.</p>
          </div>
        </div>

        <div class="animate-on-scroll group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center relative overflow-hidden">
            <svg class="w-16 h-16 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            <div class="absolute top-3 right-3 bg-white/90 text-xs font-bold text-gray-700 px-2 py-1 rounded-full">Bathroom</div>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Spa-Inspired Master Bath</h3>
            <p class="text-sm text-gray-500 mb-3">Boulder, CO</p>
            <p class="text-sm text-gray-600 leading-relaxed">Walk-in rain shower, freestanding soaker tub, heated marble floors, and custom double vanity. A true luxury retreat.</p>
          </div>
        </div>

        <div class="animate-on-scroll group bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-green-100 to-green-200 flex items-center justify-center relative overflow-hidden">
            <svg class="w-16 h-16 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <div class="absolute top-3 right-3 bg-white/90 text-xs font-bold text-gray-700 px-2 py-1 rounded-full">Addition</div>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Second-Story Addition</h3>
            <p class="text-sm text-gray-500 mb-3">Lakewood, CO</p>
            <p class="text-sm text-gray-600 leading-relaxed">400 sq ft master suite addition with walk-in closet and ensuite bath. Seamlessly matched to the existing roofline and siding.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-blue-600 font-semibold text-sm uppercase tracking-wider">How It Works</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Our Process</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          A straightforward, four-step approach designed to keep your project on time and stress-free.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {process_steps.map((item) => (
          <div class="animate-on-scroll relative text-center">
            <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-xl font-extrabold text-white">{item.step}</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Website Banner -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="animate-on-scroll bg-white rounded-2xl border border-gray-200 p-6 md:p-8 flex flex-col sm:flex-row items-center gap-6 shadow-sm">
        <div class="flex-1 text-center sm:text-left">
          <p class="text-sm font-bold text-blue-600 mb-1">Are you a contractor or trades business?</p>
          <p class="text-gray-600 text-sm">We built this site with our own templates. Get one just like it — starting at $497, no monthly fees.</p>
        </div>
        <a href={`${base}templates/`} class="inline-flex items-center bg-blue-600 text-white px-6 py-3 rounded-lg font-bold text-sm hover:bg-blue-700 transition-colors whitespace-nowrap flex-shrink-0">
          See Website Packages
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 bg-gradient-to-br from-blue-700 to-blue-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.2&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-6">
        <div class="flex text-amber-400">
          {[...Array(5)].map(() => (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-white/80 text-sm font-medium">4.9/5 from 120+ reviews</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to Get Started?
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Tell us about your project and get a free, detailed estimate within 48 hours.
      </p>
      <a
        href={`${base}contact/`}
        class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg"
      >
        Request a Free Estimate
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={serviceJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
